<script>
    // Filter agents
    function setFilter(category, btn) {
        document.querySelectorAll('.agents-tab').forEach(t => t.classList.remove('active'));
        if (btn) btn.classList.add('active');
        document.querySelectorAll('.agent-card').forEach(card => {
            if (category === 'all' || card.dataset.category === category) {
                card.classList.remove('hidden');
            } else {
                card.classList.add('hidden');
            }
        });
    }

    // Identity selection
    const IDENTITY_HINTS = {
        upstream: '已选择上游厂家 — 豆子将为你整合 GTM、产品策略、学术推广等 12 个专家能力',
        clinic:   '已选择机构端口 — 豆丁将为你整合咨询话术、运营、术后管理等 9 个专家能力',
        other:    '已选择其他身份 — 豆子将根据你的问题智能匹配最合适的专家'
    };
    const IDENTITY_AGENTS = {
        upstream: 'doudou',
        clinic:   'douding',
        other:    'doudou'
    };

    function selectIdentity(type, el) {
        document.querySelectorAll('.identity-card').forEach(c => c.classList.remove('selected'));
        el.classList.add('selected');
        localStorage.setItem('medagent_identity', type);
        const hint = document.getElementById('identityHint');
        hint.textContent = IDENTITY_HINTS[type];
        hint.classList.add('visible');
    }

    function restoreIdentity() {
        const saved = localStorage.getItem('medagent_identity');
        if (saved) {
            const card = document.getElementById('id-' + saved);
            if (card) {
                card.classList.add('selected');
                const hint = document.getElementById('identityHint');
                hint.textContent = IDENTITY_HINTS[saved];
                hint.classList.add('visible');
            }
        }
    }

    // Launch agent — 根据身份路由
    function launchAgent(agentId) {
        const identity = localStorage.getItem('medagent_identity') || 'other';
        window.location.href = '/login.html?redirect=/chat.html?agent=' + agentId + '&identity=' + identity;
    }

    // Hero / CTA 按钮 — 根据身份进入对应入口
    function enterByIdentity() {
        const identity = localStorage.getItem('medagent_identity') || 'other';
        const entryAgent = IDENTITY_AGENTS[identity];
        window.location.href = '/login.html?redirect=/chat.html?agent=' + entryAgent + '&identity=' + identity;
    }

    // Video tab switch
    function switchTab(btn, tab) {
        document.querySelectorAll('.video-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
    }

    // Check auth and update nav
    async function checkAuth() {
        try {
            const res = await fetch('/api/auth/status');
            if (res.ok) {
                const data = await res.json();
                if (data.authenticated) {
                    document.getElementById('navRight').innerHTML = `
                        <span style="font-size:0.8rem;color:var(--text-3)">👋 ${data.userName || '已登录'}</span>
                        <button class="btn-nav-primary" onclick="document.getElementById('agents').scrollIntoView({behavior:'smooth'})">选择助手</button>
                    `;
                }
            }
        } catch(e) {}
    }
    checkAuth();

    // Scroll animation
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
            }
        });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.agent-card, .feature-card').forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
        observer.observe(el);
    });
</script>
</body>
</html>
